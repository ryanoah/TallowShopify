      },
      {
        "type": "color",
        "id": "color_accent_text",
        "label": "Accent text (on buttons)",
        "default": "#FBF6EF"
      }
    ]
  },
  {
    "name": "Typography",
    "settings": [
      {
        "type": "font_picker",
        "id": "font_heading",
        "label": "Heading font",
