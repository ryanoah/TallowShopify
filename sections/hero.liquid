<section class="hero">
  <div class="hero__media">
    {%- if section.settings.image != blank -%}
      <img
        src="{{ section.settings.image | image_url: width: 1800 }}"
        alt="{{ section.settings.image.alt | default: section.settings.heading }}"
        width="{{ section.settings.image.width }}"
        height="{{ section.settings.image.height }}"
        loading="eager"
        class="hero__image"
      >
    {%- else -%}
      <div class="hero__placeholder">
        {{ 'lifestyle-1' | placeholder_svg_tag: 'hero__placeholder-svg' }}
        <span class="hero__placeholder-label">Upload a hero photo in Theme Customizer &rarr; Hero section</span>
      </div>
    {%- endif -%}
  </div>

  <div class="hero__content">
    <h1 class="hero__heading">{{ section.settings.heading }}</h1>
    {%- if section.settings.subheading != blank -%}
      <p class="hero__subheading">{{ section.settings.subheading }}</p>
    {%- endif -%}
    {%- if section.settings.button_label != blank -%}
      <a href="{{ section.settings.button_url }}" class="button button--primary">{{ section.settings.button_label }}</a>
    {%- endif -%}
  </div>
</section>

{% schema %}
{
  "name": "Hero banner",
  "tag": "section",
  "class": "shopify-section--hero",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Hero image",
      "info": "Recommended size: 1800 x 1200px"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Handmade tallow balm, straight from the farm"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Simple, nourishing skincare made in small batches with grass-fed tallow and clean ingredients."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the collection"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Hero banner"
    }
  ]
}
{% endschema %}
