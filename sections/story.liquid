<section class="story">
  <div class="container story__inner story--{{ section.settings.image_position }}">
    <div class="story__media">
      {%- if section.settings.image != blank -%}
        <img
          src="{{ section.settings.image | image_url: width: 1200 }}"
          alt="{{ section.settings.image.alt | default: section.settings.heading }}"
          width="{{ section.settings.image.width }}"
          height="{{ section.settings.image.height }}"
          loading="lazy"
          class="story__image"
        >
      {%- else -%}
        <div class="story__placeholder">
          {{ 'lifestyle-2' | placeholder_svg_tag: 'story__placeholder-svg' }}
          <span class="story__placeholder-label">Upload a photo in Theme Customizer &rarr; Our Story section</span>
        </div>
      {%- endif -%}
    </div>

    <div class="story__content">
      <h2 class="story__heading">{{ section.settings.heading }}</h2>
      <div class="story__text rte">
        {{ section.settings.body }}
      </div>
      {%- if section.settings.button_label != blank -%}
        <a href="{{ section.settings.button_url }}" class="button button--secondary">{{ section.settings.button_label }}</a>
      {%- endif -%}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Our Story",
  "tag": "section",
  "class": "shopify-section--story",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Photo",
      "info": "A portrait or behind-the-scenes photo works well here. Recommended size: 1200 x 1200px"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Our Story"
    },
    {
      "type": "richtext",
      "id": "body",
      "label": "Story text",
      "default": "<p>[Replace this with her story: how she got started making tallow balm, her background, why she cares about clean ingredients, and what makes this product different. A few short paragraphs works best.]</p>"
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button label",
      "default": "Shop the collection"
    },
    {
      "type": "url",
      "id": "button_url",
      "label": "Button link"
    }
  ],
  "presets": [
    {
      "name": "Our Story"
    }
  ]
}
{% endschema %}
